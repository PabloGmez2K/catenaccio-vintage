# Lafabrica project .gitignore

# Secrets / env
.env
.env.local
.env.*
!.env.example
*.env
*.key
*.pem
*.secret
secrets/
credentials/

# Agent / IDE state
.claude/
.cursor/
.vscode/

# Node / web
node_modules/
.next/
dist/
build/
.cache/
*.tsbuildinfo

# Python
__pycache__/
*.pyc
.venv/
venv/

# Data (only .gitignore + .md tracked)
data/*
!data/.gitignore
!data/*.md

# OS / editor
.DS_Store
Thumbs.db
*.swp

# Sueltos en raíz: imágenes deben vivir en public/ o docs/assets/
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# internal-suite extras
exports/
private/

# Discovery Intake private/raw sources
intake/


# Local OAuth/API credentials - never commit
.secrets/
**/credentials*.json
**/client_secret*.json
**/token*.json
