NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — server-side only, NEVER NEXT_PUBLIC_*
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Feature flag — set to 'true' to enable AI suggestions panel in Studio.
# Leave empty or unset to hide the panel entirely (cost-deferred default).
STUDIO_AI_ENABLED=

# WooCommerce REST API — server-side only, NEVER NEXT_PUBLIC_*
# Used by the Studio → WooCommerce draft bridge (S022C).
# WP_APP_PASSWORD is an Application Password from WP Admin → Users → catenaccio-studio-agent → Application Passwords.
# The password includes spaces in WordPress format — include the full value with spaces.
WP_SITE_URL=
WP_APP_USER=
WP_APP_PASSWORD=

# Feature flag — set to 'true' to attach Studio images (Supabase Storage public URLs)
# to the Woo draft on create (S026B). SHADOW_FIRST: leave empty/unset to keep the
# create-draft flow exactly as before, with no images[] sent.
STUDIO_WC_ATTACH_IMAGES_ENABLED=
